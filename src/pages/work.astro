<script>
  /* ──────────────────────────────────────────────────────────
   * Lazy-load + hover-play behavior for portfolio videos.
   * - preload="none" keeps heavy reels off the critical path.
   * - On pointerenter the video starts playing (muted) once
   *   it's been loaded once (load() on first hover).
   * - On pointerleave it pauses and resets to t=0 so the next
   *   hover starts from the top of the loop.
   * - IntersectionObserver pauses anything off-screen.
   * ────────────────────────────────────────────────────────── */
  const videos = document.querySelectorAll<HTMLVideoElement>('.sel-video, .lab-video');
  videos.forEach((v) => {
    v.muted = true;
    v.playsInline = true;
    v.loop = true;

    const card = v.closest('.sel-frame, .lab-frame');
    if (!card) return;

    let loadedOnce = false;
    card.addEventListener('pointerenter', () => {
      if (!loadedOnce) { v.load(); loadedOnce = true; }
      v.play().catch(() => {});
    });
    card.addEventListener('pointerleave', () => {
      v.pause();
    });
  });

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        const el = e.target as HTMLVideoElement;
        if (!e.isIntersecting && !el.paused) el.pause();
      }
    }, { threshold: 0 });
    videos.forEach((v) => io.observe(v));
  }
</script>
