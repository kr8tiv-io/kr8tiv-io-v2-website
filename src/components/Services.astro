---
/**
 * Services — 12 panels rendered server-side from SERVICES data.
 * Horizontal GSAP pin attaches client-side.
 */
import { SERVICES } from '@lib/content';
---
<section class="services" id="services">
  <div class="services-intro">
    <div class="wrap">
      <div class="services-intro-inner">
        <div>
          <div class="chapter-label mono"><span class="b"></span>II / CAPABILITIES · 011</div>
          <h2 class="chapter-title serif">
            <span class="line"><span>Eleven <span class="it">disciplines</span>.</span></span>
            <span class="line"><span>Scroll sideways.</span></span>
          </h2>
        </div>
        <p>Each discipline takes the full screen — copy to the left, frame to the right.</p>
      </div>
    </div>
  </div>
  <div class="services-pin" id="svc-pin">
    <div class="services-track" id="svc-track">
      {SERVICES.map((s) => (
        <div class="svc-panel">
          <div class="svc-inner">
            <div class="svc-copy">
              <div class="meta"><span class="b"></span>{s.tag}</div>
              <h3>{s.t.split(' ').map((word, i, arr) => (
                i === arr.length - 1 ? <span class="ac">{word}</span> : <span>{word} </span>
              ))}</h3>
              <p>{s.desc}</p>
              <div class="price">STARTING AT<span class="p">{s.price}</span></div>
            </div>
            <div class="svc-frame" data-cursor="media">
              <span class="svc-frame-bloom" aria-hidden="true"></span>
              <video muted loop playsinline preload="none">
                <source src={`/${s.v}`} type="video/mp4" />
              </video>
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="svc-rec">REC</div>
    <div class="svc-counter"><span class="n" id="svc-cnt">01</span>OF 011</div>
  </div>
</section>

<script>
  import { isPhoneClassTouch } from '@lib/devicePolicy';

  const track = document.getElementById('svc-track');
  const pin = document.getElementById('svc-pin');
  const cnt = document.getElementById('svc-cnt');

  // Touch phones/tablets: skip the GSAP horizontal-pin entirely.
  // responsive.css stacks the panels for phone-class touch devices;
  // if we still created a ScrollTrigger pin it would manufacture a
  // tall pinSpacer and make iOS landscape/portrait feel jerky.
  const isStackedServices =
    window.matchMedia('(max-width: 720px)').matches ||
    isPhoneClassTouch();

  if (track && pin && !isStackedServices) {
    const panels = track.querySelectorAll('.svc-panel');
    // The TRUE track width is the layout width of all panels PLUS the
    // margin-right gaps between them. Using `panels × offsetWidth`
    // silently drops the 100px inter-panel gaps (`margin-right: 100px`
    // in core.css), so the pin released ~1100px early and the final
    // panel got cut off before reaching the viewport.
    //
    // `scrollWidth` on the flex track reflects the real rendered
    // width including all children + their margins, and auto-updates
    // on resize via invalidateOnRefresh. This is the number the pan
    // needs to travel to bring panel 12 flush with the left edge.
    Promise.all([import('gsap'), import('gsap/ScrollTrigger')]).then(([gsapMod, stMod]) => {
      const gsap = gsapMod.gsap;
      const ScrollTrigger = stMod.ScrollTrigger;
      gsap.registerPlugin(ScrollTrigger);
      const getSlideDistance = () => Math.max(0, track.scrollWidth - window.innerWidth);
      ScrollTrigger.create({
        trigger: pin,
        start: 'top top',
        end: () => '+=' + getSlideDistance(),
        pin: true,
        scrub: 0.8,
        onUpdate: (self) => {
          const slide = getSlideDistance();
          track.style.transform = `translateX(${-self.progress * slide}px)`;
          if (cnt) {
            // Round (not floor) so the counter flips when a panel crosses
            // the viewport center — not when it starts leaving the edge.
            // Previously "02" was displayed while "003 Video Editing"
            // copy was already center-stage.
            const p = Math.max(0, Math.min(1, self.progress));
            const idx = Math.min(panels.length - 1, Math.round(p * (panels.length - 1)));
            cnt.textContent = String(idx + 1).padStart(2, '0');
          }
        },
        invalidateOnRefresh: true
      });
    }).catch((err) => console.error('[KR8·services] GSAP import failed:', err));
  }

  // === Cursor-reactive prism on each service frame ===
  // Mirrors the hero's WebGL prism: every frame reads the pointer's
  // position within its own bounding box, writes --px / --py / --active
  // as CSS custom properties, which the ::before (spectrum band) and
  // ::after (caustic line) pseudo-elements consume to tilt + brighten.
  // Lerped for smoothness — matches the hero's 0.12 factor.
  document.querySelectorAll<HTMLElement>('.svc-frame').forEach((frame) => {
    const state = { tx: 0.5, ty: 0.5, ta: 0, cx: 0.5, cy: 0.5, ca: 0 };
    let raf = 0;
    const tick = () => {
      state.cx += (state.tx - state.cx) * 0.12;
      state.cy += (state.ty - state.cy) * 0.12;
      state.ca += (state.ta - state.ca) * 0.08;
      frame.style.setProperty('--px', state.cx.toFixed(3));
      frame.style.setProperty('--py', state.cy.toFixed(3));
      frame.style.setProperty('--active', state.ca.toFixed(3));
      if (Math.abs(state.tx - state.cx) > 0.001 ||
          Math.abs(state.ty - state.cy) > 0.001 ||
          Math.abs(state.ta - state.ca) > 0.001) {
        raf = requestAnimationFrame(tick);
      } else { raf = 0; }
    };
    const kick = () => { if (!raf) raf = requestAnimationFrame(tick); };
    frame.addEventListener('pointermove', (e: PointerEvent) => {
      const r = frame.getBoundingClientRect();
      state.tx = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
      state.ty = Math.max(0, Math.min(1, (e.clientY - r.top) / r.height));
      state.ta = 1;
      kick();
    });
    frame.addEventListener('pointerleave', () => {
      state.ta = 0;
      state.tx = 0.5; state.ty = 0.5;
      kick();
    });
  });
</script>
