---
---
<section class="reel" id="reel">
  <div class="reel-pin">
    <div class="reel-bg">
      <video muted loop playsinline preload="none">
        <source src="/kr8tiv-assets/forrestbackground.mp4" type="video/mp4" />
      </video>
      <span class="reel-fade-top"   aria-hidden="true"></span>
      <span class="reel-fade-bot"   aria-hidden="true"></span>
    </div>
    <div class="reel-inner">
      {/* Translucent KR8TIV wordmark replaces the "death to generic"
          headline. The chromatic peaks + forest video render through
          the see-through fill, so the logo reads as etched-glass type
          floating over the scene. Uses the sitewide #kr8tiv-glyph
          sprite (defined in LogoSymbol.astro), so the path data is
          shared and infinite-crisp at any size. */}
      <svg class="reel-logo" viewBox="0 0 1800 600" aria-label="KR8TIV" preserveAspectRatio="xMidYMid meet">
        <use href="#kr8tiv-glyph" />
      </svg>
    </div>
  </div>
</section>

<style>
  /* Forest video bleeds into the sections above (Work / whisper CTA)
     and below (Contact) instead of butting up as a hard rectangle.
     Two fixed-position gradients matching the section's #000 backdrop
     ride above the video at the top and bottom edges. */
  .reel { background: #000; }
  .reel-bg { isolation: isolate; }
  .reel-fade-top,
  .reel-fade-bot {
    position: absolute;
    left: 0; right: 0;
    height: 26vh;
    pointer-events: none;
    z-index: 1;
  }
  .reel-fade-top {
    top: 0;
    background: linear-gradient(to bottom,
      #000 0%, rgba(0,0,0,.92) 28%, rgba(0,0,0,.55) 60%,
      rgba(0,0,0,.18) 86%, transparent 100%);
  }
  .reel-fade-bot {
    bottom: 0;
    background: linear-gradient(to top,
      #000 0%, rgba(0,0,0,.92) 28%, rgba(0,0,0,.55) 60%,
      rgba(0,0,0,.18) 86%, transparent 100%);
  }

  /* === Translucent KR8TIV wordmark — replaces the headline ===
     Width clamps so the logo always sits comfortably inside the
     reel-pin (max-width caps it at ~1100px on huge displays so it
     doesn't blow past the centred composition). The dual fill +
     stroke gives a dual-read: a faint white wash inside the letters
     so the wordmark holds on busy scenes, plus a crisp 1.2px stroke
     around every edge so the silhouette stays legible even where the
     fill is too low-contrast against the chromatic peaks. */
  .reel-logo {
    display: block;
    width: clamp(420px, 62vw, 1100px);
    height: auto;
    margin: 0 auto;
    fill: rgba(255, 255, 255, .18);
    stroke: rgba(255, 255, 255, .65);
    stroke-width: 1.2;
    vector-effect: non-scaling-stroke;
    /* Subtle outer glow that picks up the magenta accent the rest of
       the page leans on. Renders as a faint magenta halation around
       the wordmark, ties the logo to the brand even when the chromatic
       peaks are colour-shifting underneath. */
    filter:
      drop-shadow(0 0 12px rgba(255, 255, 255, .14))
      drop-shadow(0 0 36px rgba(255, 106, 213, .22));
    /* mix-blend-mode: overlay lets the chromatic peaks shimmer through
       the fill — the wordmark literally becomes etched glass. */
    mix-blend-mode: overlay;
  }
  @media (max-width: 720px) {
    .reel-logo { width: 88vw; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initKatanaTrail } from '@lib/katanaTrail';
  gsap.registerPlugin(ScrollTrigger);
  // Skip the pin on mobile — responsive.css lays the reel out as a
  // normal block so no ScrollTrigger pinSpacer is needed. Ken-burns
  // scale on the video still runs at all sizes.
  const reelMobile = window.matchMedia('(max-width: 720px)').matches;
  if (document.querySelector('.reel')) {
    if (!reelMobile) {
      ScrollTrigger.create({
        trigger: '.reel', start: 'top top', end: 'bottom bottom',
        pin: '.reel-pin', pinSpacing: false
      });
    }
    gsap.to('.reel-bg video', {
      scale: 1.12, ease: 'none',
      scrollTrigger: { trigger: '.reel', start: 'top top', end: 'bottom top', scrub: true }
    });
  }

  // Cursor-drawn katana trail + three.js reel scene are deferred until
  // this section approaches the viewport. This keeps heavy GL setup out
  // of the initial home-page boot path.
  const reelPin = document.querySelector<HTMLElement>('.reel-pin');
  if (reelPin && !reelMobile) {
    let fxBooted = false;
    const bootReelFx = (): void => {
      if (fxBooted) return;
      fxBooted = true;
      try {
        initKatanaTrail(reelPin, {
          color:           [1.0, 0.55, 0.86],
          trailFade:       0.93,
          brushSize:       11,
          chromaticOffset: 6,
          velocityBoost:   85
        });
      } catch (err) {
        console.error('[KR8·reel] katanaTrail init failed:', err);
      }

      // Three.js layered scene: volumetric prism slab + refractive
      // mirror lake. Both sample the same forest VideoTexture.
      import('@lib/reelScene').then(({ initReelScene }) => {
        const video = reelPin.querySelector<HTMLVideoElement>('.reel-bg video');
        if (!video) return;
        // Wait for first frame so VideoTexture has data to sample.
        const start = (): void => {
          try {
            initReelScene(reelPin, video, {
              slabTint:       [1.0, 0.55, 0.86],
              lakeTint:       [0.92, 0.62, 0.95],
              slabDispersion: 0.018,
              lakeRipple:     0.045
            });
          } catch (err) {
            console.error('[KR8·reel] reelScene init failed:', err);
          }
        };
        if (video.readyState >= 2) start();
        else video.addEventListener('loadeddata', start, { once: true });
      }).catch((err) => console.error('[KR8·reel] reelScene import failed:', err));
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          bootReelFx();
        }
      }, { rootMargin: '320px 0px', threshold: 0.01 });
      io.observe(reelPin);
    } else {
      bootReelFx();
    }
  }
</script>
