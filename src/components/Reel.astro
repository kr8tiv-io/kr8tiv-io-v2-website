---
---
<section class="reel" id="reel">
  <div class="reel-pin">
    <div class="reel-bg">
      <video muted loop playsinline preload="none">
        <source src="/kr8tiv-assets/forrestbackground.mp4" type="video/mp4" />
      </video>
      <span class="reel-fade-top"   aria-hidden="true"></span>
      <span class="reel-fade-bot"   aria-hidden="true"></span>
    </div>
    <div class="reel-inner">
      {/* Animated noise.gif overlay (pulled from kr8tiv.io). Tiled
          across the reel box and screen-blended so the chromatic peaks
          + forest video shimmer through the grain. Reads as a film-
          texture wash over the scene, not a wordmark.
          aria-hidden because it's purely decorative — no information
          for screen readers. */}
      <span class="reel-noise" aria-hidden="true"></span>
    </div>
  </div>
</section>

<style>
  /* Forest video bleeds into the sections above (Work / whisper CTA)
     and below (Contact) instead of butting up as a hard rectangle.
     Two fixed-position gradients matching the section's #000 backdrop
     ride above the video at the top and bottom edges. */
  .reel { background: #000; }
  .reel-bg { isolation: isolate; }
  .reel-fade-top,
  .reel-fade-bot {
    position: absolute;
    left: 0; right: 0;
    height: 26vh;
    pointer-events: none;
    z-index: 1;
  }
  .reel-fade-top {
    top: 0;
    background: linear-gradient(to bottom,
      #000 0%, rgba(0,0,0,.92) 28%, rgba(0,0,0,.55) 60%,
      rgba(0,0,0,.18) 86%, transparent 100%);
  }
  .reel-fade-bot {
    bottom: 0;
    background: linear-gradient(to top,
      #000 0%, rgba(0,0,0,.92) 28%, rgba(0,0,0,.55) 60%,
      rgba(0,0,0,.18) 86%, transparent 100%);
  }

  /* === Animated noise.gif overlay — replaces the headline ===
     Tiled film-grain texture covering the reel box. screen-blend so
     dark pixels of the gif dissolve and only the brighter sparkle
     pixels add a shimmering noise wash to the chromatic peaks. The
     gif itself is 320x240 → background-size keeps the original
     pixel scale (no upscaling artefacts) and `repeat` tiles it
     across the full box. */
  .reel-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url('/kr8tiv-assets/noise.gif');
    background-repeat: repeat;
    background-size: 320px 240px;
    mix-blend-mode: screen;
    /* Slight cap on intensity — the raw gif read as too aggressive at
       100% opacity over the chromatic peaks. */
    opacity: .55;
    z-index: 3;
  }
  @media (prefers-reduced-motion: reduce) {
    .reel-noise { opacity: .25; }
  }
  html.motion-off .reel-noise { opacity: .25; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { initKatanaTrail } from '@lib/katanaTrail';
  gsap.registerPlugin(ScrollTrigger);
  // Skip the pin on mobile — responsive.css lays the reel out as a
  // normal block so no ScrollTrigger pinSpacer is needed. Ken-burns
  // scale on the video still runs at all sizes.
  const reelMobile = window.matchMedia('(max-width: 720px)').matches;
  if (document.querySelector('.reel')) {
    if (!reelMobile) {
      ScrollTrigger.create({
        trigger: '.reel', start: 'top top', end: 'bottom bottom',
        pin: '.reel-pin', pinSpacing: false
      });
    }
    gsap.to('.reel-bg video', {
      scale: 1.12, ease: 'none',
      scrollTrigger: { trigger: '.reel', start: 'top top', end: 'bottom top', scrub: true }
    });
  }

  // Cursor-drawn katana trail + three.js reel scene are deferred until
  // this section approaches the viewport. This keeps heavy GL setup out
  // of the initial home-page boot path.
  const reelPin = document.querySelector<HTMLElement>('.reel-pin');
  if (reelPin && !reelMobile) {
    let fxBooted = false;
    const bootReelFx = (): void => {
      if (fxBooted) return;
      fxBooted = true;
      try {
        initKatanaTrail(reelPin, {
          color:           [1.0, 0.55, 0.86],
          trailFade:       0.93,
          brushSize:       11,
          chromaticOffset: 6,
          velocityBoost:   85
        });
      } catch (err) {
        console.error('[KR8·reel] katanaTrail init failed:', err);
      }

      // Three.js layered scene: volumetric prism slab + refractive
      // mirror lake. Both sample the same forest VideoTexture.
      import('@lib/reelScene').then(({ initReelScene }) => {
        const video = reelPin.querySelector<HTMLVideoElement>('.reel-bg video');
        if (!video) return;
        // Wait for first frame so VideoTexture has data to sample.
        const start = (): void => {
          try {
            initReelScene(reelPin, video, {
              slabTint:       [1.0, 0.55, 0.86],
              lakeTint:       [0.92, 0.62, 0.95],
              slabDispersion: 0.018,
              lakeRipple:     0.045
            });
          } catch (err) {
            console.error('[KR8·reel] reelScene init failed:', err);
          }
        };
        if (video.readyState >= 2) start();
        else video.addEventListener('loadeddata', start, { once: true });
      }).catch((err) => console.error('[KR8·reel] reelScene import failed:', err));
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          bootReelFx();
        }
      }, { rootMargin: '320px 0px', threshold: 0.01 });
      io.observe(reelPin);
    } else {
      bootReelFx();
    }
  }
</script>
