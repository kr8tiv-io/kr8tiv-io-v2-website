---
/**
 * KintsugiOverlay — full-viewport shatter menu, rendered into every
 * layout. Triggered by:
 *   · click:    any element with `data-kintsugi-trigger`
 *   · custom:   window.dispatchEvent(new CustomEvent('kintsugi:open'))
 *   · keyboard: Esc closes when open
 * Crack paths + label data are generated by src/lib/kintsugi.ts
 * (initKintsugi) so markup stays terse here.
 */
---
<div id="kintsugi-overlay" class="kintsugi-overlay" aria-hidden="true" role="dialog" aria-label="Full navigation menu" data-open="false">
  <button type="button" class="kin-close" aria-label="Close menu">
    <span aria-hidden="true">✕</span>
    <span class="kin-close-hint">esc</span>
  </button>
  <svg class="kin-cracks" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true"></svg>
  <div class="kin-center" aria-hidden="true">
    <span class="kin-center-glyph">侍</span>
    <span class="kin-center-label">pick a path</span>
  </div>
</div>
