---
/**
 * Base layout shared across every variant page.
 * Handles <head>, fonts, grain/noise overlays, nav, scroll-progress bar,
 * custom cursor, and mounts the shared client-side lib wiring (Lenis,
 * GSAP ticker sync, motion toggle, magnetic CTAs, white-light easter
 * egg). Variant-specific logic is handled inside the variant's <slot>.
 *
 * SEO surface lives inside <Seo />. Pass page-level props through.
 */
import '@styles/core.css';
import '@styles/light-theme.css';  /* cohesive light palette when data-theme="light" */
import '@styles/responsive.css';   /* comprehensive mobile + tablet overrides */
import Nav from '@components/Nav.astro';
import VariantBar from '@components/VariantBar.astro';
import WhiteLightOverlay from '@components/WhiteLightOverlay.astro';
import LogoSymbol from '@components/LogoSymbol.astro';
import Seo from '@components/Seo.astro';
import OracleOverlay from '@components/OracleOverlay.astro';
import KintsugiOverlay from '@components/KintsugiOverlay.astro';
import Footer from '@components/Footer.astro';
import type { FaqItem, HowToStep, Crumb } from '@components/Seo.astro';

export interface Props {
  title?: string;
  description?: string;
  variant?: string;
  activeVariant?: string;
  canonical?: string;
  ogImage?: string;
  pageType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'CollectionPage' | 'Article';
  breadcrumbs?: Crumb[];
  faqs?: FaqItem[];
  howTo?: { name: string; description: string; totalTime?: string; steps: HowToStep[] };
  keywords?: string[];
  currentNav?: 'home' | 'process' | 'start' | 'work' | 'terms' | 'other';
}

const {
  /* Title trimmed from 84ch (over the 60ch SEO recommendation) to
     58ch — passes SeaOcean's title-length check, keeps the brand
     mark + the cyber-renaissance positioning. */
  title = 'KR8TIV · Cyber-renaissance design atelier (侍)',
  /* Description trimmed from 232ch (over 160ch) to 156ch — fits
     SERP snippet width without truncation. */
  description = 'Cyber-renaissance design atelier. Brand, web, motion, video, and AI business solutions for founders who want to be memorable, not generic.',
  variant = 'prism',
  activeVariant = 'v8-prism',
  canonical,
  ogImage,
  pageType,
  breadcrumbs,
  faqs,
  howTo,
  keywords,
  currentNav = 'home'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark" data-variant={variant}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <Seo
    title={title}
    description={description}
    canonical={canonical}
    ogImage={ogImage}
    type={pageType}
    breadcrumbs={breadcrumbs}
    faqs={faqs}
    howTo={howTo}
    keywords={keywords}
  />
  <link rel="icon" href="/kr8tiv-assets/cropped-Design-24-32x32.png" />
  <link rel="apple-touch-icon" href="/kr8tiv-assets/cropped-Design-24-32x32.png" />
  <link rel="manifest" href="/manifest.webmanifest" />

  <!-- Speculation Rules: prerender neighboring variant pages so the
       variant-bar feels instant on Chrome/Edge. -->
  <script type="speculationrules" is:inline set:html={JSON.stringify({
    prerender: [{ source: 'document', where: { href_matches: '/kr8tiv-v*' }, eagerness: 'moderate' }]
  })}></script>

  <!-- Fonts — variable axes imported so font-variation-settings can be
       tweened at runtime by scroll velocity / hover state. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://calendly.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@100..800&family=Inter+Tight:wght@100..900&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- Inline SVG defs: logo glyph + liquid-glass filter, reachable by
       url(#liquidGlass) / <use href="#kr8tiv-glyph"> from any component. -->
  <LogoSymbol />

  <div class="grain"></div>
  <div class="noise"></div>
  <canvas id="trail-canvas"></canvas>
  <div class="cur" id="cur"><span class="l" id="cur-l"></span></div>
  <div class="prog" id="prog"></div>

  <Nav current={currentNav} />

  <main>
    <slot />
  </main>

  <Footer />

  <VariantBar active={activeVariant} />
  <WhiteLightOverlay />

  <!-- HYBRID · sitewide menu layers -->
  <OracleOverlay />
  <KintsugiOverlay />

  <!-- Client-side wiring. Astro bundles this through Vite — tree-shakes
       unused exports. Type-checked at build time. -->
  <script>
    import { initScrollCore } from '@lib/scrollCore';
    import { initCursor } from '@lib/cursor';
    import { initMotionToggle } from '@lib/motionToggle';
    import { initMusic, initAudioReactiveNote } from '@lib/audioNote';
    import { initSceneAnnouncer } from '@lib/a11yAnnounce';
    import { initLazyVideos } from '@lib/lazyVideo';
    import { initOracle } from '@lib/oracle';
    import { initKintsugi } from '@lib/kintsugi';
    import { initMultiStateNav } from '@lib/multiStateNav';

    // Resilience wrapper: one init failing must not silently cascade
    // into later inits. Previously a stale Vite dep cache for gsap/lenis
    // would throw in initScrollCore and kill every later init in the
    // chain (including the Oracle + Kintsugi menu bindings) — leaving
    // the user with no navigable UI. Each init is now isolated.
    const safe = (name: string, fn: () => unknown): void => {
      try { fn(); } catch (err) { console.error(`[KR8] ${name} failed:`, err); }
    };

    // Non-critical visual layers are deferred to idle so first paint /
    // interaction comes from the core nav + scroll systems first.
    const onIdle = (fn: () => void): void => {
      const w = window as Window & {
        requestIdleCallback?: (cb: IdleRequestCallback, opts?: IdleRequestOptions) => number;
      };
      if (typeof w.requestIdleCallback === 'function') {
        w.requestIdleCallback(() => fn(), { timeout: 1200 });
      } else {
        window.setTimeout(fn, 280);
      }
    };

    safe('scrollCore',       () => initScrollCore());
    safe('cursor',           () => initCursor());
    safe('motionToggle',     () => initMotionToggle());
    safe('music',            () => initMusic());
    safe('audioReactiveNote',() => initAudioReactiveNote());
    safe('sceneAnnouncer',   () => initSceneAnnouncer());
    safe('lazyVideos',       () => initLazyVideos());
    onIdle(() => {
      void Promise.all([
        import('@lib/cursorTrail'),
        import('@lib/whiteLight'),
        import('@lib/kineticType'),
        import('@lib/asciiDither'),
        import('@lib/seatCounter')
      ]).then(([trail, white, kinetic, ascii, seats]) => {
        safe('cursorTrail', () => trail.initCursorTrail());
        safe('whiteLight',  () => white.initWhiteLight());
        safe('kineticType', () => kinetic.initKineticType());
        safe('asciiDither', () => ascii.initAsciiDither());
        safe('seatCounter', () => seats.initSeatCounter());
      }).catch((err) => {
        console.error('[KR8] deferred visual inits failed:', err);
      });
    });

    // HYBRID nav system (3 layers) — isolated so stale GSAP/Lenis
    // cache in the earlier block never blocks the menu.
    safe('oracle',           () => initOracle());
    safe('kintsugi',         () => initKintsugi());
    safe('multiStateNav',    () => initMultiStateNav());

    // Theme toggle lives in @lib/theme — persists + respects system pref
    import('@lib/theme').then((m) => safe('theme', () => m.initTheme()));

    if (import.meta.env.DEV) {
      console.log('%c[KR8TIV / PRISM · 08] 侍 — astro build', 'color:#ff6ad5;font:600 12px monospace');
      console.log('%c↳ Press W for white light', 'color:#f2f1ec;font:400 11px monospace');
    }
  </script>
</body>
</html>
