---
/**
 * Layout for MDX case-study / editorial pages — simpler chrome than
 * the full splash-page layout. Drops prism-specific scripts (no hero
 * video, no reveal) and ships only the shared nav + grain overlay.
 */
import '@styles/core.css';
import '@styles/build-notes.css';
import Nav from '@components/Nav.astro';
import LogoSymbol from '@components/LogoSymbol.astro';
import WhiteLightOverlay from '@components/WhiteLightOverlay.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  frontmatter?: {
    title?: string;
    description?: string;
    canonical?: string;
  };
}

const frontmatter = Astro.props.frontmatter ?? {};
const title = Astro.props.title || frontmatter.title || 'KR8TIV build notes';
const description =
  Astro.props.description ||
  frontmatter.description ||
  'Build notes from KR8TIV: WebGL, motion, Astro architecture, and the craft behind the Prism site.';
const canonicalPath = Astro.props.canonical || frontmatter.canonical || Astro.url.pathname;
const canonical = new URL(canonicalPath, Astro.site ?? 'https://kr8tiv.io').toString();
---
<!DOCTYPE html>
<html lang="en" data-theme="dark" data-variant="editorial">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="article" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" href="/kr8tiv-assets/cropped-Design-24-32x32.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@100..800&family=Inter+Tight:wght@100..900&display=swap"
    rel="stylesheet"
  />

  <!-- Google Analytics 4 (gtag.js) — same property as BaseLayout. -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MC0STCCGFY"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MC0STCCGFY');
  </script>
</head>
<body>
  <LogoSymbol />
  <div class="noise"></div>
  <div class="cur" id="cur"><span class="l" id="cur-l"></span></div>
  <div class="prog" id="prog"></div>
  <Nav />
  <main class="case-study">
    <article>
      <slot />
    </article>
  </main>
  <WhiteLightOverlay />
  <script>
    import { initScrollCore } from '@lib/scrollCore';
    import { initCursor } from '@lib/cursor';
    import { initWhiteLight } from '@lib/whiteLight';
    import { initMotionToggle } from '@lib/motionToggle';
    import { initAsciiDither } from '@lib/asciiDither';
    initScrollCore();
    initCursor();
    initWhiteLight();
    initMotionToggle();
    initAsciiDither();
  </script>
</body>
</html>
